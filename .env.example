# 复制本文件为 .env 并填值：cp .env.example .env
# .env 已被 .gitignore，不会入库。

# ── Basic Auth（必填）──────────────────────────────────────
# 壳子的唯一鉴权。本机和远程访问都用这一对账号密码。
# 务必改成你自己的强密码，不要用示例值。
BASIC_AUTH_USER=admin
BASIC_AUTH_PASS=change-me

# 你在对话 prompt 和界面里显示的名字（如"张三"）。
# 留空则回落到 BASIC_AUTH_USER，再回落到"用户"。
USER_NAME=

# ── 语音输入（可选，不配则麦克风按钮失效）──────────────────
# 火山引擎 · 录音文件识别大模型 (新版控制台单 X-Api-Key 鉴权)
# 来源: https://console.volcengine.com/speech/new/setting/apikeys
ARK_API_KEY=
# 识别模型，留空用默认 doubao-seed-asr-2-0
ARK_ASR_MODEL=

# ── Hot App Radar 子应用（可选，仅 radar 用）────────────────
# 在 https://www.producthunt.com/v2/oauth/applications 创建应用，
# 复制 "Developer Token"（不是 client secret）。
PRODUCT_HUNT_TOKEN=
